--- !u!114 &1323365065
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1323365063}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\U0001F3AE Objective\n\nScore points by guessing songs based on emoji
    clues created by the opposing team.\n\n\U0001F9D1\u200D\U0001F91D\u200D\U0001F9D1
    Setup\nEnter player or team names.\nTake turns adding songs to a shared pool
    of 10 songs total.\nYou may skip your turn if you don\u2019t want to add a song.\n\U0001F504
    Each Round\n\U0001F3AF 1. Clue Setup\nOne team selects a song from the shared
    pool.\nThey choose emojis to represent the song.\nBe creative\u2026 but don\u2019t
    make it too easy.\n\U0001F501 2. Pass the Device\nHand the device to the other
    team.\nThey press Ready when prepared.\n\U0001F914 3. Guess the Song\nThe guessing
    team sees only the emojis.\nThey enter their guess before time runs out.\nThey
    can also skip if stuck.\n\U0001F3C6 4. Scoring\n\u2705 Correct guess \u2192 Guessing
    team earns 1 point\n\u23ED\uFE0F Skip \u2192 Opposing team earns 1 point\n\U0001F501
    Continue\nTurns alternate each round.\nSongs are removed once used.\nPlay continues
    until all songs are gone.\n\U0001F3C1 End Game\nThe team with the most points
    wins!\n\U0001F4A1 Tips\nUse emojis that hint at lyrics, vibe, or theme\nThink
    like your opponent \u2014 not too obvious, not impossible\nHave fun with it \U0001F608"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
