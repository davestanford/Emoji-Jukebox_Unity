  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Objective\n\nScore points by guessing songs based on emoji clues created
    by the opposing team.\n\n Setup\nEnter player or team names.\nTake turns adding
    songs to a shared pool of 10 songs total.\nYou may skip your turn if you don\u2019t
    want to add a song.\n Each Round\n 1. Clue Setup\nOne team selects a song from
    the shared pool.\nThey choose emojis to represent the song.\nBe creative\u2026
    but don\u2019t make it too easy.\n 2. Pass the Device\nHand the device to the
    other team.\nThey press Ready when prepared.\n 3. Guess the Song\nThe guessing
    team sees only the emojis.\nThey enter their guess before time runs out.\nThey
    can also skip if stuck.\n 4. Scoring\n Correct guess \u2192 Guessing team earns
    1 point\n Skip \u2192 Opposing team earns 1 point\n Continue\nTurns alternate
    each round.\nSongs are removed once used.\nPlay continues until all songs are
    gone.\n End Game\nThe team with the most points wins!\n Tips\nUse emojis that
    hint at lyrics, vibe, or theme\n "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
